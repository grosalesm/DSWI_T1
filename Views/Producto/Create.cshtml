@model DSWI_T1_RosalesGian.Dtos.ProductoDto

<div class="container mt-5">
    <h2 class="my-4">Registrar Producto</h2>

    <form asp-action="Create" method="post" class="shadow p-4 rounded bg-light">
        <div class="mb-3">
            <label asp-for="NomProducto" class="form-label">Nombre del Producto</label>
            <input type="text" asp-for="NomProducto" class="form-control" required>
        </div>

        <div class="mb-3">
            <label asp-for="Precio" class="form-label">Precio</label>
            <input type="number" step="0.01" asp-for="Precio" class="form-control">
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Registrar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>