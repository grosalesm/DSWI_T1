@model DSWI_T1_RosalesGian.Dtos.LlamadaDto

<h1>Formulario de Llamada</h1>
<p>@ViewData["Instruccion"]</p>
<hr />

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-controller="Llamada" asp-action="Registrar" method="post">
    <div class="form-group">
        <label asp-for="Minutos">Cantidad de Minutos:</label>
        <input asp-for="Minutos" class="form-control" type="number" />
    </div>
    <br />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Calcular Costo</button>

        <a asp-controller="Producto" asp-action="Index" class="btn btn-secondary">
            Volver al Inicio
        </a>
    </div>
</form>